<Window x:Class="Bibliothicc.CategoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="Categories" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDeepBrush}">
    <Grid>
        <Border Background="{StaticResource BgSurfaceBrush}"
                CornerRadius="12" Margin="16"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <DockPanel Margin="20,16">
                <!-- Title -->
                <TextBlock DockPanel.Dock="Top" Text="Categories"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <!-- Action buttons at bottom -->
                <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Button x:Name="ButtonBack" DockPanel.Dock="Right"
                            Style="{StaticResource GhostButton}"
                            Width="80" Height="34" IsCancel="True">
                        <TextBlock Text="Close"/>
                    </Button>
                    <Button x:Name="ButtonChangeCategory" DockPanel.Dock="Right"
                            Style="{StaticResource BaseButton}"
                            Width="100" Height="34" Margin="0,0,8,0"
                            Click="ButtonChangeCategory_Click">
                        <TextBlock Text="✎  Rename"/>
                    </Button>
                    <Button x:Name="ButtonAddCategory" Style="{StaticResource AccentButton}"
                            Height="34" Click="ButtonAddCategory_Click">
                        <TextBlock Text="+ New Category" FontWeight="SemiBold"/>
                    </Button>
                </DockPanel>

                <!-- Category list -->
                <ListView x:Name="ListViewSystemCategories"
                          Style="{StaticResource ModernListView}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource ModernListViewItem}">
                            <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Symbol}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</Window>
