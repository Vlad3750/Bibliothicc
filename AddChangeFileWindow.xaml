<Window x:Class="Bibliothicc.AddChangeFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="AddChangeFileWindow" Height="350" Width="auto" MinWidth="350" MaxWidth="550">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label x:Name="LabelAddChange" Content="Add Film:" FontSize="20"></Label>
        <Grid Grid.Row="1" Margin="0 0 3 0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <Label Content="Path:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <DockPanel Grid.Row="0" Grid.Column="1">
                <Button x:Name="ButtonFileOpenerPath" DockPanel.Dock="Right" Height="35" Width="35" FontSize="20" BorderBrush="#FFABADB3" Click="ButtonFileOpenerPath_Click">📂</Button>
                <TextBox x:Name="TextBoxPath" VerticalContentAlignment="Center" FontSize="15" Height="35"></TextBox>
            </DockPanel>

            <Label Content="Name:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <TextBox x:Name="TextBoxFileName" Grid.Row="1" Grid.Column="1" Height="35" VerticalContentAlignment="Center" FontSize="15"></TextBox>

            <Label Content="Thumbnail:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <DockPanel Grid.Row="2" Grid.Column="1">
                <Button x:Name="ButtonFileOpenerThumbnail" DockPanel.Dock="Right" Height="35" Width="35" FontSize="20" BorderBrush="#FFABADB3" Click="ButtonFileOpenerThumbnail_Click">📂</Button>
                <TextBox x:Name="TextBoxThumbnail" Height="35" VerticalContentAlignment="Center" FontSize="15"></TextBox>
            </DockPanel>

            <Label Content="Category:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <DockPanel HorizontalAlignment="Left" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
                    <Button x:Name="ButtonAddCategory" DockPanel.Dock="Right" Width="20" Height="20" Content="+" Click="ButtonAddCategory_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="90"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                <ListView x:Name="ListViewCategoriesToAdd" BorderThickness="0" Width="auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="10">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Padding="0 0 5 0" BorderThickness="0" Background="Transparent" Content="✕" Click="ButtonRemoveCategory_Click"/>
                                    <Label Content="{Binding Name}"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ButtonAddChange" Width="100" Height="30" Margin="10" IsDefault="True" Click="ButtonAddChange_Click">Add</Button>
            <Button x:Name="ButtonCancel" Width="100" Height="30" Margin="10" IsCancel="True" Grid.Column="1">Cancel</Button>
        </Grid>
    </Grid>
</Window>
