<Window x:Class="Bibliothicc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="Bibliothicc" Height="650" Width="1050"
        Background="{StaticResource BgDeepBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="200"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App title -->
                <Border DockPanel.Dock="Top" Padding="16,18,16,14"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📚" FontSize="22" Margin="0,0,0,4"/>
                        <TextBlock Text="Bibliothicc" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Media Library" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- User info + Logout at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="12,10"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <Button x:Name="ButtonLoginLogout" DockPanel.Dock="Right"
                                Style="{StaticResource IconButton}"
                                Width="30" Height="30"
                                ToolTip="Logout"
                                Click="ButtonLoginLogout_Click">
                            <Image Source="/Bilder/log_out_icon.png" Width="16" Height="16"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Logged in as" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <Label x:Name="LabelUserName" Content="user1" Padding="0"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Add Library button -->
                <Border DockPanel.Dock="Bottom" Padding="12,8">
                    <Button x:Name="ButtonAddLib" Style="{StaticResource AccentButton}"
                            Height="34" Click="ButtonAddLib_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="+" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="New Library" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Section label -->
                <TextBlock DockPanel.Dock="Top" Text="M  Y     L  I  B  R  A  R  I  E  S"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="16,14,16,6"/>

                <!-- Libraries list -->
                <ListView x:Name="ListViewLibraries"
                          Style="{StaticResource ModernListView}"
                          ItemContainerStyle="{StaticResource ModernListViewItem}"
                          Margin="8,0"
                          SelectionChanged="ListViewLibraries_SelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════ MAIN AREA ═══════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- Top Bar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1"
                    Padding="16,10">
                <DockPanel>
                    <!-- Right: Settings + Quit -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ButtonSetttings" Style="{StaticResource GhostButton}"
                                Padding="10,6" Margin="0,0,4,0"
                                Click="ButtonSetttings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ButtonQuit" Style="{StaticResource GhostButton}"
                                Padding="10,6" Click="ButtonQuit_Click">
                            <TextBlock Text="✕  Quit" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <!-- Search bar -->
                    <Border Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                            CornerRadius="8" Padding="10,0"
                            MaxWidth="420" Height="36" VerticalAlignment="Center">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="🔍" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox x:Name="TextBoxSearchBar"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"
                                     Text="Search here ..."
                                     GotFocus="TextBoxSearchBar_GotFocus"
                                     LostFocus="TextBoxSearchBar_LostFocus"/>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Toolbar: CRUD + Category filter -->
            <Border DockPanel.Dock="Top" Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1"
                    Padding="16,8">
                <DockPanel>
                    <!-- Right: Category filter + Stats + Play -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ButtonStats" Style="{StaticResource GhostButton}"
                                Padding="10,6" Margin="0,0,8,0"
                                Visibility="Visible"
                                Click="ButtonStats_Click">
                            <TextBlock Text="📊 Stats"/>
                        </Button>

                        <DockPanel x:Name="DockPanelCategory" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0" FontSize="12"/>
                            <ComboBox x:Name="ComboBoxCategory"
                                      Style="{StaticResource ModernComboBox}"
                                      Height="32" MinWidth="120">
                                <ComboBoxItem IsSelected="True">All Categories</ComboBoxItem>
                            </ComboBox>
                        </DockPanel>

                        <Button x:Name="ButtonPlay" Style="{StaticResource AccentButton}"
                                Width="36" Height="36" Padding="0"
                                Visibility="Visible">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="▶" FontSize="13"/>
                        </Button>
                    </StackPanel>

                    <!-- Left: Add / Change / Delete -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ButtonAddFile" Style="{StaticResource AccentButton}"
                                Padding="12,6" Margin="0,0,6,0"
                                Click="ButtonAddFile_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Add" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ButtonChange" Style="{StaticResource BaseButton}"
                                Padding="12,6" Margin="0,0,6,0"
                                Click="ButtonChange_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✎" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Edit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ButtonDelete" Style="{StaticResource DangerButton}"
                                Padding="12,6"
                                Click="ButtonDelete_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Delete" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- File List -->
            <Border Background="{StaticResource BgDeepBrush}" Padding="16">
                <ListView x:Name="ListViewFiles"
                          Style="{StaticResource ModernListView}"
                          ItemContainerStyle="{StaticResource ModernListViewItem}"/>
            </Border>
        </DockPanel>
    </Grid>
</Window>
