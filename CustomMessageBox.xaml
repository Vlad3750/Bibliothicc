<Window x:Class="Bibliothicc.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" SizeToContent="WidthAndHeight"
        MinWidth="280" MaxWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
            CornerRadius="10" Padding="24,20">
        <StackPanel>
            <!-- Icon + Message -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock x:Name="TextBlockIcon" Foreground="{DynamicResource TextPrimaryBrush}" Text="ℹ️"
                           FontSize="20" VerticalAlignment="Top" Margin="0,0,12,0"/>
                <TextBlock x:Name="TextBlockMessage"
                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap" MaxWidth="320" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ButtonCancel" Grid.Column="0"
                        Style="{DynamicResource GhostButton}"
                        Height="34" Visibility="Collapsed" Click="ButtonCancel_Click">
                    <TextBlock Text="Cancel" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="ButtonOK" Grid.Column="2"
                        Style="{DynamicResource AccentButton}"
                        Height="34" IsDefault="True" Click="ButtonOK_Click">
                    <TextBlock Text="OK" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>