<Window x:Class="Bibliothicc.BrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Browse Public Libraries" Height="550" Width="860"
        Background="{DynamicResource BgDeepBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: library list -->
        <Border Grid.Column="0" Background="{DynamicResource BgSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,14"
                        BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🌐" FontSize="20" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Public Libraries" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Browse what others shared" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="L  I  B  R  A  R  I  E  S"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="16,12,16,6"/>

                <ListView x:Name="ListViewPublicLibraries"
                          Style="{DynamicResource ModernListView}"
                          ItemContainerStyle="{DynamicResource ModernListViewItem}"
                          Margin="8,0"
                          SelectionChanged="ListViewPublicLibraries_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,2">
                                <Button DockPanel.Dock="Right"
                                        Style="{DynamicResource GhostButton}"
                                        Padding="6,3" Margin="6,0,0,0"
                                        ToolTip="Download all files"
                                        Tag="{Binding}"
                                        Click="ButtonDownloadLibrary_Click">
                                    <TextBlock Text="⬇" FontSize="13"/>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding FileType}" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- Main: media list -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel>
                    <TextBlock x:Name="TextBlockLibraryName" Text="Select a library"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TextBlockLibraryType" Text=""
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BgDeepBrush}" Padding="16">
                <ListView x:Name="ListViewMedia"
                          Style="{DynamicResource ModernListView}"
                          ItemContainerStyle="{DynamicResource ModernListViewItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,2">
                                <Button DockPanel.Dock="Right"
                                        Style="{DynamicResource AccentButton}"
                                        Width="30" Height="30" Padding="0"
                                        Margin="8,0,0,0"
                                        ToolTip="Open file"
                                        Tag="{Binding}"
                                        Click="ButtonOpenFile_Click">
                                    <TextBlock Text="▶" FontSize="12"/>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding MimeType}" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </DockPanel>
    </Grid>
</Window>
