<Window x:Class="Bibliothicc.AddLibWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="New Library" Height="350" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDeepBrush}">
    <Grid>
        <Border Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="12" Margin="16"
                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
            <StackPanel Margin="24,20">
                <!-- Title -->
                <TextBlock x:Name="LabelAddLib" Text="New Library"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,20"/>

                <!-- Name -->
                <TextBlock Text="Library Name" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="TextBoxLibName" Style="{DynamicResource ModernTextBox}"
                         Height="36" Margin="0,0,0,14" Padding="4" FontSize="12" TextChanged="TextBoxLibName_TextChanged"/>

                <!-- Data Type -->
                <TextBlock Text="Media Type" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="ComboBoxDataTyp" Style="{DynamicResource ModernComboBox}"
                          Height="36" Margin="0,0,0,20">
                    <ComboBoxItem Content="Video (.mp4)" IsSelected="True"/>
                    <ComboBoxItem Content="Movie (.mkv/.mp4/.mov)"/>
                    <ComboBoxItem Content="Text (.txt/.md/.docx/.pdf)"/>
                    <ComboBoxItem Content="Picture (.png/.jpg/.svg)"/>
                    <ComboBoxItem Content="Audio (.mp3/.wav/.ogg)"/>
                </ComboBox>

                <!-- Buttons -->
                <DockPanel>
                    <Button x:Name="ButtonCancel" DockPanel.Dock="Right"
                            Style="{DynamicResource GhostButton}"
                            Width="90" Height="36" IsCancel="True" Margin="8,0,0,0">
                        <TextBlock Text="Cancel"/>
                    </Button>
                    <Button x:Name="ButtonAdd" Style="{DynamicResource AccentButton}"
                            Height="36" IsDefault="True" Click="ButtonAdd_Click">
                        <TextBlock Text="Create Library" FontWeight="SemiBold"/>
                    </Button>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
