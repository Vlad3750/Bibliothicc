<Window x:Class="Bibliothicc.SettingsWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="SettingsWindows" Height="250" Width="400">
    <DockPanel>
        <Label DockPanel.Dock="Top" FontSize="15">Settings:</Label>
        <DockPanel HorizontalAlignment="Center" VerticalAlignment="Top">
            <Label Margin="0 0 20 0">Darkmode:</Label>
                <Button x:Name="ButtonDarkmode" Background="Transparent" VerticalContentAlignment="Center" Width="50" BorderThickness="0" Click="Button_Click">
                    <Image Source="/Bilder/button_aus.png"/>
                </Button>
        </DockPanel>
    </DockPanel>
</Window>
