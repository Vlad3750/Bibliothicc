<Window x:Class="Bibliothicc.LoginRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="Bibliothicc — Login" Height="auto" MaxHeight="600" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeepBrush}">
    <Grid>
        <Border Background="{StaticResource BgSurfaceBrush}"
                CornerRadius="12" Margin="24"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <StackPanel Margin="32,28">
                <!-- Header -->
                <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="LabelLoginRegister" Text="Welcome back"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to your library"
                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="TextBoxUserName" Style="{StaticResource ModernTextBox}"
                         Height="38" Text="user1" Padding="4" FontSize="12" Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBoxPasswd" Style="{StaticResource ModernPasswordBox}"
                             Height="38" Password="1" Padding="4" FontSize="12" Margin="0,0,0,14"/>

                <!-- Repeat Password (register only) -->
                <Grid x:Name="GridRepeatPasswd" Visibility="Collapsed" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Repeat Password" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBoxRepeatPasswd"
                                     Style="{StaticResource ModernPasswordBox}"
                                     Height="38" Password="1" Padding="4" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <!-- Buttons -->
                <Button x:Name="ButtonLogin" Style="{StaticResource AccentButton}"
                        Height="40" IsDefault="True" Margin="0,4,0,10"
                        Click="ButtonLogin_Click">
                    <TextBlock Text="Sign In" FontSize="14" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="ButtonRegister" Style="{StaticResource GhostButton}"
                        Height="36" Click="ButtonRegister_Click">
                    <TextBlock Text="Create account" FontSize="13"
                               Foreground="{StaticResource AccentBrush}"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
