<Window x:Class="Bibliothicc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Background="Gray">
            <Grid DockPanel.Dock="Left" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Label Content="Bibliothicc" FontSize="30"/>
                <Border Background="White"  Margin="20 0 0 0" DockPanel.Dock="Top" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Height="40" CornerRadius="20" Padding="5">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Width="25" Height="25" BorderThickness="0" Background="Transparent" IsDefault="True">
                            <Image Source="/Bilder/magnifyingglass.png"/>
                        </Button>
                        <TextBox x:Name="TextBoxSearchBar" Width="400" Height="20" Margin="2 0 0 0" BorderThickness="0" Padding="2" GotFocus="TextBoxSearchBar_GotFocus" LostFocus="TextBoxSearchBar_LostFocus" VerticalContentAlignment="Center" Foreground="LightGray" Text="Search here ..."></TextBox>
                    </DockPanel>
                </Border>
            </Grid>
            <Grid Height="auto" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ButtonStats" Content="Stats" Background="Transparent" Click="ButtonStats_Click"/>
                <Button x:Name="ButtonLoginLogout" Grid.Column="1" Padding="10 0" Background="Transparent" Click="ButtonLoginLogout_Click">
                    <DockPanel>
                        <Image Source="/Bilder/log_out_icon.png" Width="20" DockPanel.Dock="Right"/>
                        <Label x:Name="LabelUserName">user1</Label>
                    </DockPanel>
                </Button>
                <Button x:Name="ButtonQuit" Content="Quit" Grid.Column="2" Background="Transparent" Click="ButtonQuit_Click"/>
            </Grid>
        </DockPanel>
        <DockPanel DockPanel.Dock="Left" Width="150">
            <Button x:Name="ButtonOtherLibs" DockPanel.Dock="Bottom" Height="30" Content="Other Libs"></Button>
            <DockPanel VerticalAlignment="Top">
                <Button x:Name="ButtonAddLib" DockPanel.Dock="Bottom" Height="30" Click="ButtonAddLib_Click">+</Button>
                <ListView x:Name="ListViewLibraries" Padding="5">
                    <ListViewItem>TestLib</ListViewItem>
                </ListView>
            </DockPanel>
        </DockPanel>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top">
                <Grid x:Name="GridCRUD" Width="340">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ButtonAddFile" Content="Add +" Height="30" Margin="5,5,5,0" Grid.Column="0" Click="ButtonAddFile_Click" VerticalAlignment="Top"/>
                    <Button x:Name="ButtonChange" Content="Change ~" Height="30" Margin="5" Grid.Column="1" Click="ButtonChange_Click"/>
                    <Button x:Name="ButtonDelete" Content="Delete -" Height="30" Margin="5" Grid.Column="2" Click="ButtonDelete_Click"/>
                    <Button x:Name="ButtonPlay" Content="⯈" Width="30" Height="30" Margin="5" Grid.Column="3">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="90"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
                <DockPanel x:Name="DockPanelCategory" Width="220" HorizontalAlignment="Right">
                    <Label DockPanel.Dock="Left" x:Name="LabelCategory" VerticalAlignment="Center">Category:</Label>
                    <ComboBox x:Name="ComboBoxCategory" Height="30" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <ComboBoxItem IsSelected="True">TestCategory</ComboBoxItem>
                    </ComboBox>
                </DockPanel>
            </DockPanel>
            <DockPanel DockPanel.Dock="Right" Width="30">
                <Button x:Name="ButtonSetttings" DockPanel.Dock="Bottom" Height="30" Click="ButtonSetttings_Click">⚙</Button>
                <Button x:Name="ButtonChangeView" DockPanel.Dock="Bottom" Height="30">👁</Button>
                <ScrollBar Margin="0 10"></ScrollBar>
            </DockPanel>
            <ListView x:Name="ListViewFiles">
                <ListViewItem>TestItem</ListViewItem>
            </ListView>
        </DockPanel>
    </DockPanel>
</Window>
