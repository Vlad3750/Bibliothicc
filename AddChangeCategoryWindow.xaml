<Window x:Class="Bibliothicc.AddChangeCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="AddChangeCategories" Height="150" Width="250">
    <Grid Margin="-3,0,3,0">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label x:Name="LabelAddChangeCategory" Content="Add Category:" FontSize="20"/>
        <Grid Grid.Row="1" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Name:" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox x:Name="TextBoxAddChangeCategory" Grid.Column="1"></TextBox>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ButtonAddChangeCategory" Content="Add" Margin="10"/>
            <Button x:Name="ButtonCancel" IsCancel="True" Content="Cancel" Margin="10" Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>
