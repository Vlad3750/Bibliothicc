<Window x:Class="Bibliothicc.AddLibWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bibliothicc"
        mc:Ignorable="d"
        Title="AddLibWindow" Height="220" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label x:Name="LabelAddLib" Content="Add New Library:" FontSize="20"></Label>
        <Grid Grid.Row="1" Margin="0 0 3 0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <TextBox x:Name="TextBoxLibName" Grid.Row="0" Grid.Column="1" Height="35" VerticalContentAlignment="Center"></TextBox>

            <Label Content="DataTyp:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"></Label>
            <ComboBox x:Name="ComboBoxDataTyp" Grid.Row="1" Grid.Column="1" Height="35" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Video (.mp4)" IsSelected="True"/>
                <ComboBoxItem Content="Movie (.mkv/.mp4)"/>
                <ComboBoxItem Content="Text (.txt/.md/.docx/.pdf)"/>
                <ComboBoxItem Content="Picture (.png/.jpeg/./.svg)"/>
            </ComboBox>
        </Grid>
        <Grid Grid.Row="2" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ButtonAdd" Width="100" Height="30" Margin="10" IsDefault="True" Click="ButtonAdd_Click">Add</Button>
            <Button x:Name="ButtonCancel" Width="100" Height="30" Margin="10" IsCancel="True" Grid.Column="1">Cancel</Button>
        </Grid>
    </Grid>
</Window>
